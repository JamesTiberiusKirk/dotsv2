type MongoCollection interface {
	InsertOne(ctx context.Context, document any, opts ...*options.InsertOneOptions) (*mongo.InsertOneResult, error)
	UpdateOne(ctx context.Context, filter any, update any, opts ...*options.UpdateOptions) (*mongo.UpdateResult, error)
	FindOne(ctx context.Context, filter any, opts ...*options.FindOneOptions) *mongo.SingleResult
	FindOneAndUpdate(ctx context.Context, filter any, update any, opts ...*options.FindOneAndUpdateOptions) *mongo.SingleResult
	Find(ctx context.Context, filter any, opts ...*options.FindOptions) (cur *mongo.Cursor, err error)
}

const (
	collectionHandsets  = "handsets"
	collectionContracts = "contracts"
)

type storage struct {
	tmongo.Mongo
	handsetsCollection  MongoCollection
	contractsCollection MongoCollection
}

func NewStorage(ctx context.Context, mongo tmongo.Mongo) (*storage, error) {
	db := &storage{
		Mongo:               mongo,
		handsetsCollection:  mongo.Client.Database(mongo.Database).Collection(collectionHandsets),
		contractsCollection: mongo.Client.Database(mongo.Database).Collection(collectionContracts),
	}

	err := db.ensureIndexes(ctx, mongo)
	if err != nil {
		return nil, err
	}

	return db, nil
}

func (s storage) ensureIndexes(ctx context.Context, mongoDb tmongo.Mongo) error {
	err := tmongo.CreateIndexes(ctx, mongoDb, tmongo.CollectionIndexesMap{
		collectionHandsets: {
			mongo.IndexModel{
				Keys:    bson.M{"id": 1},
				Options: options.Index().SetName("id").SetUnique(true).SetSparse(true),
			},
			mongo.IndexModel{
				Keys:    bson.M{"billID": 1},
				Options: options.Index().SetName("bill_id").SetUnique(true).SetSparse(true),
			},
		},
		collectionContracts: {
			mongo.IndexModel{
				Keys:    bson.M{"id": 1},
				Options: options.Index().SetName("contract_id").SetUnique(true),
			},
			mongo.IndexModel{
				Keys:    bson.M{"requestId": 1},
				Options: options.Index().SetName("contract_request_id").SetUnique(true),
			},
			mongo.IndexModel{
				Keys:    bson.M{"serviceId": 1},
				Options: options.Index().SetName("contract_service_id"),
			},
		},
	})()

	return err
}

// UpsertHandset upserts a handset from the legacy equinoxdb/cron path (no versioning).
func (s storage) UpsertHandset(ctx context.Context, handset handsetdb.Handset) error {
	m := bson.M{
		"id": handset.ID,
	}

	if handset.Name != "" {
		m["name"] = handset.Name
	}
	if handset.RetailPrice != "" {
		m["retailPrice"] = handset.RetailPrice
	}
	if handset.ContractPrice != "" {
		m["contractPrice"] = handset.ContractPrice
	}
	if handset.ContractTerm != "" {
		m["contractTerm"] = handset.ContractTerm
	}
	m["active"] = handset.Active
	m["outOfStock"] = handset.OutOfStock

	_, err := s.handsetsCollection.
		UpdateOne(ctx, bson.M{"id": handset.ID}, bson.M{"$set": m}, options.Update().SetUpsert(true))
	if err != nil {
		return fmt.Errorf("could not upsert handset: %w", err)
	}
	return nil
}

// UpsertHandsetModel upserts a models.Handset with versioning support.
// When currentProperties.Version changes, the old properties are pushed into the versions array.
func (s storage) UpsertHandsetModel(ctx context.Context, handset models.Handset) error {
	// Fetch the existing document to determine if currentProperties has changed
	var existing models.Handset
	err := s.handsetsCollection.FindOne(ctx, bson.M{"billID": handset.BillID}).Decode(&existing)
	if err != nil && !errors.Is(err, mongo.ErrNoDocuments) {
		return fmt.Errorf("could not fetch existing handset: %w", err)
	}

	update := bson.M{}

	if err == nil {
		// Document exists – push old currentProperties into versions if version changed
		if existing.CurrentProperties.Version != "" && existing.CurrentProperties.Version != handset.CurrentProperties.Version {
			update["$push"] = bson.M{"versions": existing.CurrentProperties}
		}
	}

	// Ensure newly inserted handsets have a stable UUID id.
	update["$setOnInsert"] = bson.M{
		"id": uuid.New(),
	}

	update["$set"] = bson.M{
		"billID":            handset.BillID,
		"active":            handset.Active,
		"currentProperties": handset.CurrentProperties,
	}

	_, err = s.handsetsCollection.
		UpdateOne(ctx, bson.M{"billID": handset.BillID}, update, options.Update().SetUpsert(true))
	if err != nil {
		return fmt.Errorf("could not upsert handset: %w", err)
	}

	return nil
}

func (s storage) GetHandsets(ctx context.Context, isInStock bool) ([]models.Handset, error) {
	filter := bson.M{"active": true}
	if isInStock {
		filter["quantityInStock"] = bson.M{"$gt": 0}
	}

	cur, err := s.handsetsCollection.Find(ctx, filter)
	if err != nil {
		return nil, fmt.Errorf("could not find handsets: %w", err)
	}

	defer func(cur *mongo.Cursor, ctx context.Context) {
		err := cur.Close(ctx)
		if err != nil {
			tlog.Error(ctx, "could not close cursor: %s", err.Error())
		}
	}(cur, ctx)

	var handsets []models.Handset
	for cur.Next(ctx) {
		var handset models.Handset
		err := cur.Decode(&handset)
		if err != nil {
			return nil, fmt.Errorf("could not decode handset: %w", err)
		}
		handsets = append(handsets, handset)
	}

	if err := cur.Err(); err != nil {
		return nil, fmt.Errorf("error iterating over handsets: %w", err)
	}

	return handsets, nil
}

func (s storage) GetHandsetByID(ctx context.Context, handsetID uuid.UUID) (*models.Handset, error) {
	var h models.Handset
	err := s.handsetsCollection.FindOne(ctx, bson.M{"id": handsetID}).Decode(&h)
	if err != nil {
		if errors.Is(err, mongo.ErrNoDocuments) {
			return nil, terrors.ErrNotFound
		}
		return nil, fmt.Errorf("could not find handset by id: %w", err)
	}
	return &h, nil
}

