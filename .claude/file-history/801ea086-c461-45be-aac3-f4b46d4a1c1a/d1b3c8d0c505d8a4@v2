func TestConsumeMobileHandsetContractApprovedUsesApprovedEventLoanValues(t *testing.T) {
	t.Parallel()

	ctrl := gomock.NewController(t)
	store := mockConsumer.NewMockStorage(ctrl)
	accountClient := mockConsumer.NewMockAccountClient(ctrl)
	loanboxClient := mockConsumer.NewMockLoanboxClient(ctrl)
	consumerSvc := consumer.New(store, accountClient, loanboxClient)

	store.EXPECT().
		GetContractByID(gomock.Any(), testContractUUID).
		Return(&models.Contract{
			ID:                testContractUUID,
			RequestID:         "request-1",
			Status:            models.ContractStatusEligibilityApproved,
			BankAccountNumber: "12345678",
			BankTitle:         "Barclays",
		}, nil)

	accountClient.EXPECT().
		GetAccount(gomock.Any(), &accountgateway.GetAccountRequest{AccountId: "customer-1"}).
		Return(&accountgateway.GetAccountResponse{Account: &accountgateway.Account{}}, nil)

	loanboxClient.EXPECT().
		CreateLoan(gomock.Any(), gomock.Any()).
		DoAndReturn(func(_ context.Context, req loanboxclient.CreateLoanRequest) (*loanboxclient.CreateLoanResponse, error) {
			if req.AmountApproved != 950 {
				t.Fatalf("expected approved event retail price, got %.2f", req.AmountApproved)
			}
			if req.TermMonths != 24 {
				t.Fatalf("expected approved event contract months, got %d", req.TermMonths)
			}
			if req.BankAccountNumber != "12345678" {
				t.Fatalf("expected contract bank account number, got %q", req.BankAccountNumber)
			}
			return &loanboxclient.CreateLoanResponse{LoanApplicationID: 123}, nil
		})

	store.EXPECT().
		UpdateContractLoanReference(gomock.Any(), "request-1", "123").
		Return(nil)

	store.EXPECT().
		UpdateContractStatus(gomock.Any(), "request-1", models.ContractStatusApproved).
		Return(nil)

	acked := false
	err := consumerSvc.ConsumeMobileHandsetContractApproved(
		context.Background(),
		&message.Envelope{Id: "event-1"},
		&serviceevents.MobileHandsetContractApproved{
			ServiceId:      "service-1",
			CustomerId:     "customer-1",
			ContractId:     testContractUUID.String(),
			HandsetId:      "h-1",
			RetailPrice:    &serviceevents.Money{Amount: "950", Currency: "GBP"},
			ContractMonths: "24",
		},
		func() error {
			acked = true
			return nil
		},
	)
	if err != nil {
		t.Fatalf("ConsumeMobileHandsetContractApproved returned error: %v", err)
	}
	if !acked {
		t.Fatal("expected message to be acked")
	}
}
