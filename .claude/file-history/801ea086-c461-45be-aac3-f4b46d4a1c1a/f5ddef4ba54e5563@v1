syntax = "proto3";
package service_events;
option go_package = "github.com/utilitywarehouse/telecom-mobile/pkg/generated/protos/mobile/v1/events/serviceevents";

import "google/protobuf/timestamp.proto";
import "github.com/utilitywarehouse/telecom-equipment/protos/events.proto";
import "mobile/v1/apis/termination_service.proto";
import "mobile/v1/apis/syniverse_gateway.proto";
import "mobile/v1/apis/esim_stock_service.proto";

import "github.com/utilitywarehouse/protoc-gen-protostrate/protostrate.proto";

option (protostrate.generate) = true;
option (protostrate.mock) = true;

// MobileServiceRequestedEvent means a customer has requested a new mobile
// service.  This will typically happen as a part of order processing.
//
// Note that ideally, we would generate a service_id and this would also be in
// here, but we're not able to do that until more of the overall process is
// controlled in the new platform.
message MobileServiceRequested {
  string order_id = 1;
  string quote_id = 2;
  string customer_id = 3;  // customer UUID
  string tariff_id = 4;
  oneof porting {
    STAC stac = 5;
    PAC pac = 6;
  }
  string service_id = 7;
  SimType sim_type = 8;
}

// MobileServiceCreated is the logical second part of MobileServiceRequested. At
// this point, the requesting is completed and state will begin to be tracked
// properly in the new platform.
//
// Emitted as the result of processing an order
// FABRICATION: emit upon discovery of a mobile cli (servicerequestevent)
//
// Note that ideally, this event would not need to exist and could be merged
// with MobileServiceRequested (simply by adding service_id to it).  The reason
// it exists for now is that the service_id generation logic (and data required
// to do it) only exists in Bill.
message MobileServiceCreated {
  string service_id = 1;
  string order_id = 2;  // optional, will not be present for discovered services
  // where platform did not handle provisoning
  string customer_id = 3;  // Customer UUID
  string tariff_id = 4;
  // This existing purely for integrations with bill and should not be consumed
  // otherwise
  string bill_service_ref = 5 [deprecated = true];
}

// Signal to indicate the request for a mobile supplies tariff to change
// Trigger for provisioning
message MobileTariffChangeRequested {
  string service_id = 1;
  string new_tariff_id = 2;
  string quote_id = 3;
  string customer_id = 4;
  string order_id = 5;
  google.protobuf.Timestamp effective_date = 6;
}

// FABRICATION: emit upon discovery of a mobile cli (servicerefchanged)
message MobileMSISDNChanged {
  string service_id = 1;
  string msisdn = 2;
}

// FABRICATION: emit upon discovery of a mobile cli (servicerefchanged)
message MobileSimNumberChanged {
  string service_id = 1;
  string sim_number = 2;
}

// FABRICATION: emit upon promo code changing from one known value to another
message MobileTariffChanged {
  string service_id = 1;
  string new_tariff_id = 2;
}

// Customer triggered event signaling the customer wishes to activate and start
message MobileServiceActivationRequested {// no init fab
  string service_id = 1;
  google.protobuf.Timestamp requested_date = 2;
  string source = 3;
}

// Customer triggered event signaling the customer wishes to activate a replacement (via SIMCHG)
message MobileReplacementActivationRequested {// no init fab
  string service_id = 1;
  google.protobuf.Timestamp requested_date = 2;
  string source = 3;
  string old_sim_number = 4;
  string new_sim_number = 5;
}

// A positive response to the activation request, good response from industry,
// trigger for billing FABRICATION: emit when live date <= now
// (servicestartedevent)
message MobileServiceActivated {
  string service_id = 1;
}

// The request to end a mobile service and disconnect the supply with industry
message MobileServiceDisconnectionRequest {
  termination_service.TerminateRequest request = 1;
}

// A postive response from industry to a disconnection request
// FABRICATION: emit on end date >= now (servicestoppedevent)
message MobileServiceDisconnected {
  string service_id = 1;
}

message MobileNameChanged {
  string service_id = 1;
  string name = 2;
}

// MobileServiceEquipmentRequested describes a request for mobile service
// equipment.
message MobileServiceEquipmentRequested {
  string order_id = 1;
  string service_id = 2;
  string customer_id = 3;
  events.InventoryType equipment_type = 4;
  repeated events.InventoryType package_content = 5;
  enum requestReason {
    NEW_SIM = 0;
    REPLACEMENT_SIM = 1;
  }

  requestReason reason = 6;
  oneof request_info {
    ESimRequestInfo esim_request_info = 7;
  }
}

message ESimRequestInfo {
  string request_email = 1;
}

// MobileServiceEquipmentDispatched describes a dispatched for mobile service
// equipment.
message MobileServiceEquipmentDispatched {
  string order_id = 1;
  string service_id = 2;
  string equipment_serial_number = 3;
  events.InventoryType equipment_type = 4;
  oneof equipment_info {
    ESimEquipmentInfo esim_info = 5;
  }
}

message ESimEquipmentInfo {
  string msisdn = 1;
  string activation_url = 2;
  string serial_number = 3;
  bool is_replacement = 4;
  string request_email = 5;
}

// MobileSimReplacementDispatched describes a replacement sim dispatched.
message MobileSimReplacementDispatched {
  string order_id = 1;
  string service_id = 2;
  string equipment_serial_number = 3;
  events.InventoryType equipment_type = 4;
}

message MobileTariff {
  enum Feature {
    FEAT_UNKNOWN = 0;
    FEAT_WIFI_AND_4G_CALLING = 1;
    FEAT_EU_ROAMING = 2;
    FEAT_5G = 3;
  }
  string tariff_id = 1;
  string name = 2;
  string description = 3;
  Money cost = 4;
  Money discount = 5;
  repeated MobileTariffAllowance allowances = 6;
  bool budgetControl = 7;
  bool canBackdate = 8;
  bool canToggleBudgetControl = 9;
  repeated Feature features = 10;
  string canBackdateAtDate = 11;
  bool mustBackdate = 12;
}

message MobileTariffAllowance {
  oneof allowance {
    MobileTariffMinutesAllowance minutes = 1;
    MobileTariffSMSAllowance sms = 2;
    MobileTariffDataAllowance data = 3;
  }
}

message MobileTariffMinutesAllowance {
  bool unlimited = 1;
  uint64 value = 2;
}

message MobileTariffSMSAllowance {
  bool unlimited = 1;
  uint64 value = 2;
}

message MobileTariffDataAllowance {
  bool unlimited = 1;
  uint64 value = 2;
}

message Money {
  string amount = 1;
  string currency = 2;  // example: GBP
}

message MobileService {
  enum ServiceState {
    UNKNOWN = 0;
    PENDING = 1;
    LIVE = 2;
    ENDED = 3;
  }
  string service_id = 1;
  string tariff_id = 2;
  string sim_number = 3;
  string cli = 4;
  // This existing purely for integrations with bill and should not be consumed
  // otherwise
  string bill_service_ref = 5 [deprecated = true];
  string name = 6;
  ServiceState state = 7;
}

// Triggered for port upfront/in-life requests
message MobilePortRequested {
  string service_id = 1;
  string order_id = 2;
  string customer_id = 3;
  oneof port {
    PAC pac = 4;
    STAC stac = 5;
  }
}

// Triggered when the pac/stac code have gone through syniverse validation,
// regardless of success or error
message MobilePortValidated {
  string service_id = 1;
  string customer_id = 2;
  string order_id = 3;
  port_validation_error validation_error = 4;

  // if nil, then the port is valid
  enum port_validation_error {
    PortValidated_NO_ERROR = 0;  // no nullable in proto3, workaround
    PortValidated_INVALID = 1;
    PortValidated_EXPIRED = 2;
    PortValidated_ALREADY_USED = 3;
    PortValidated_ABOUT_TO_EXPIRE = 4;
    PortValidated_SYNIVERSE_ERROR = 5;
    PortValidated_ARCHIVED = 6;
  }

  enum code_type {
    STAC = 0;
    PAC = 1;
  }

  string cli = 5;
  string code = 6;
  google.protobuf.Timestamp expiration_date = 7;
  string port_id = 8;
  syniverse_gateway.PortStatus syniverse_code_status = 9;
  code_type type = 10;
}

// Triggered by porting service when service is activated
message MobilePortStarted {
  string port_id = 1;
  string service_id = 2;
  string order_id = 3;
  string msisdn = 4;  // donor
  string code = 5;
  string sim_serial_number = 6;
  google.protobuf.Timestamp expiration_date = 7;
  string customer_id = 8;

  enum code_type {
    STAC = 0;
    PAC = 1;
  }

  code_type type = 9;
}

message STAC {
  google.protobuf.Timestamp date = 1;
  string code = 2;
  string cli = 3;
}

message PAC {
  string cli = 1;
  string code = 2;
}

message MobileSimSettingsChangeRequested {
  string service_id = 1;
  repeated SimSetting setting = 2;
}

message MobileSimSettingChanged {
  string service_id = 1;
  SimSetting setting = 2;
}

// Triggered by my-services-api when a refund is requested for a budget
// controlled SIM
message MobileTopUpRefundRequested {
  string service_id = 1;
  Money refund = 2;
  Money additional_charge = 3;
  string refund_id = 4;
}

message SimSetting {
  enum Setting {
    SETTING_UNKNOWN = 0;
    SETTING_INTERNATIONAL_CALLING = 1;
    SETTING_ROAMING = 2;
    SETTING_ADULT_CONTENT = 3;
    SETTING_PREMIUM_TEXT_CALL = 4;
    SETTING_CALL_CAP = 5;
    SETTING_ROAMING_INTERNATIONAL = 6;
  }
  string name = 1;
  string description = 2;
  bool enabled = 3;
  Setting setting = 4;
  uint64 value = 5;  // only used for call cap
  google.protobuf.Timestamp applies_at = 6;
}

// MobileContractRenewalDateReceived is used to insert new customers previous
// contract renewal dates in big query
message MobileContractRenewalDateReceived {
  string customer_id = 1;
  string end_date = 2;
  string current_supplier = 3;
  string advisor = 4;
}

enum SimType {
  P_SIM = 0;
  E_SIM = 1;
}

message MobileFraudAlertTriggered {
  string service_id = 1;
  AlertType alert_type = 2;
  int32 volume  = 3;
  int32 unique_opns  = 4;
}

enum AlertType {
  ALERT_TYPE_UNKNOWN = 0;
  ALERT_TYPE_NEW_SERVICE_SMS_THRESHOLD = 1;
}

// Produced when a customer requests a handset contract and the eligibility
// check is initiated with the third party.
message MobileHandsetContractRequested {
  string service_id = 1;
  string customer_id = 2;
  string contract_id = 3;
  string handset_id = 4;
}

// Produced when a handset contract passes eligibility and is approved.
// Downstream services will use this to order the handset from inventory.
message MobileHandsetContractApproved {
  string service_id = 1;
  string customer_id = 2;
  string contract_id = 3;
  string handset_id = 4;
  string handset_name = 5;
  Money contract_price = 6;
  Money retail_price = 7;
  string contract_months = 8;
}

// Produced when a handset contract fails eligibility and is declined.
message MobileHandsetContractDeclined {
  string service_id = 1;
  string customer_id = 2;
  string contract_id = 3;
  string handset_id = 4;
}

// Produced when the handset order comment code has been posted to bill.
message MobileHandsetOrdered {
  string service_id = 1;
  string customer_id = 2;
  string contract_id = 3;
  string handset_id = 4;
}

// Produced when a handset contract expired.
message MobileHandsetContractExpired {
  string service_id = 1;
  string customer_id = 2;
  string contract_id = 3;
  string handset_id = 4;
}
