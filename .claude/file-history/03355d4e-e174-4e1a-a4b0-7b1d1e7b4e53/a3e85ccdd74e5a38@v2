// ── build nodes & edges ──────────────────────────────────────────────────────

const nodes = [];
const edges = [];
const edgeSet = new Set();

// Accumulate line counts per system (including ancestors)
const systemLineCounts = {};
systemDefs.forEach(s => { systemLineCounts[s.id] = 0; });

function getAncestors(sysId) {
  const sys = systemDefs.find(s => s.id === sysId);
  if (!sys || !sys.parentId) return [];
  return [sys.parentId, ...getAncestors(sys.parentId)];
}

allFiles.forEach(f => {
  const sysId = getSystemId(f.relativePath);
  systemLineCounts[sysId] = (systemLineCounts[sysId] || 0) + f.lineCount;
  getAncestors(sysId).forEach(a => {
    systemLineCounts[a] = (systemLineCounts[a] || 0) + f.lineCount;
  });
});

// Collect files per system for health checks
const filesBySystem = {};
allFiles.forEach(f => {
  const id = getSystemId(f.relativePath);
  if (!filesBySystem[id]) filesBySystem[id] = [];
  filesBySystem[id].push(f);
});

// System nodes
systemDefs.forEach(s => {
  const directFiles = filesBySystem[s.id] || [];
  const [health, healthReason] = directFiles.length > 0
    ? systemHealth(directFiles)
    : ['green', null];
  const node = {
    id: s.id, label: s.label, type: 'system', icon: s.icon,
    parentId: s.parentId, filePath: s.filePath,
    lineCount: systemLineCounts[s.id] || 0, health,
  };
  if (s.summary) node.summary = s.summary;
  if (healthReason) node.healthReason = healthReason;
  nodes.push(node);
});

// File nodes
allFiles.forEach(f => {
  const sysId = getSystemId(f.relativePath);
  const [health, healthReason] = fileHealth(f.lineCount, f.importCount);
  const node = {
    id: fileSlug(f.relativePath), label: f.name, type: 'file', icon: 'file',
    parentId: sysId, filePath: f.relativePath, lineCount: f.lineCount, health,
  };
  if (healthReason) node.healthReason = healthReason;
  nodes.push(node);
});

