function slugify(s) {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function fileSlug(relativePath) {
  return 'file-' + slugify(relativePath);
}

// Determine health based on file metrics
function fileHealth(file) {
  if (file.lineCount > 500) return ['red', `${file.lineCount} lines — too large`];
  if (file.lineCount > 300) return ['yellow', `${file.lineCount} lines — large`];
  if ((file.imports || []).length > 12) return ['yellow', `${(file.imports||[]).length} imports`];
  return ['green', null];
}

function systemHealth(files) {
  const maxLines = Math.max(...files.map(f => f.lineCount));
  if (maxLines > 500) return ['red', 'contains 500+ line files'];
  if (maxLines > 300) return ['yellow', 'contains large files'];
  if (files.length > 15) return ['yellow', 'large system, consider nesting'];
  return ['green', null];
}

