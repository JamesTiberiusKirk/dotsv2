// MobileCanResendESimActivationEmail is the resolver for the mobileCanResendESimActivationEmail field.
func (r *queryResolver) MobileCanResendESimActivationEmail(ctx context.Context, request *model.MobileCanResendESimActivationEmailRequest) (*model.MobileCanResendESimActivationEmailResponse, error) {
	customerAuth, err := r.authorize(ctx, cerbos.RESEND_ESIM_ACTIVATION)
	if err != nil {
		return nil, err
	}

	// Query api.
	apiResponse, err := r.LifecycleEventCommsProcessorApiClient.GetResendableCommunications(
		ctx,
		&lecpPb.GetResendableCommunicationsRequest{
			CustomerId: customerAuth.AccountID,
		},
	)
	if err != nil {
		return nil, err
	}

	// Identify esim activation communication for this service from returned comms.
	var esimComm *lecpPb.ResendableCommunication
	for _, comm := range apiResponse.Resendable {
		if comm.Type == lecpPb.ResendableType_RESENDABLE_TYPE_ESIM_ACTIVATION_EMAIL &&
			(comm.ServiceId != nil && *comm.ServiceId == request.ServiceID) {
			esimComm = comm
			break
		}
	}
	if esimComm == nil {
		return &model.MobileCanResendESimActivationEmailResponse{
			Resendable: false,
		}, nil
	}

	// Build response.
	response := &model.MobileCanResendESimActivationEmailResponse{
		Resendable: esimComm.Resendable,
	}
	if esimComm.NextSend != nil {
		nextSendStr := utils.TimestampbbToString(esimComm.NextSend)
		response.NextSend = &nextSendStr
	}
	if esimComm.ExpiresAt != nil {
		expiresAtStr := utils.TimestampbbToString(esimComm.ExpiresAt)
		response.ExpiresAt = &expiresAtStr
	}
	return response, nil
}

// MobileAvailableHandsets is the resolver for the mobileAvailableHandsets field.
func (r *queryResolver) MobileAvailableHandsets(ctx context.Context, serviceID string, includeOutOfStock *bool) ([]*sharedmodel.MobileHandsetBrand, error) {
	customerAuth, err := r.authorize(ctx, cerbos.GET_AVAILABLE_HANDSETS)
	if err != nil {
		return nil, err
	}

	resp, err := r.HandsetApiClient.GetAvailableHandsets(ctx, &handsetpb.GetAvailableHandsetsRequest{
		ServiceId:  serviceID,
		CustomerId: customerAuth.AccountNumber,
	})
	if err != nil {
		return nil, err
	}

	type modelKey struct{ manufacturer, model string }
	type modelData struct {
		handsets []*handsetpb.Handset
	}

	brandOrder := []string{}
	brandSeen := map[string]bool{}
	brandModels := map[string][]string{}
	modelSeen := map[modelKey]bool{}
	modelHandsets := map[modelKey]*modelData{}

	for _, h := range resp.GetHandsets() {
		mk := modelKey{h.GetManufacturer(), h.GetModel()}
		if !brandSeen[h.GetManufacturer()] {
			brandSeen[h.GetManufacturer()] = true
			brandOrder = append(brandOrder, h.GetManufacturer())
		}
		if !modelSeen[mk] {
			modelSeen[mk] = true
			brandModels[h.GetManufacturer()] = append(brandModels[h.GetManufacturer()], h.GetModel())
			modelHandsets[mk] = &modelData{}
		}
		modelHandsets[mk].handsets = append(modelHandsets[mk].handsets, h)
	}

	sort.Strings(brandOrder)

	var brands []*sharedmodel.MobileHandsetBrand
	for _, brandName := range brandOrder {
		models := brandModels[brandName]
		sort.Strings(models)

		var phones []*sharedmodel.MobileHandsetPhone
		for _, modelName := range models {
			mk := modelKey{brandName, modelName}
			data := modelHandsets[mk]

			colourSeen := map[string]bool{}
			storageSeen := map[string]bool{}
			var colours, storages []string
			var variants []*sharedmodel.MobileHandsetVariant
			var fromPricePence int32

			for _, h := range data.handsets {
				if !colourSeen[h.GetColours()] {
					colourSeen[h.GetColours()] = true
					colours = append(colours, h.GetColours())
				}
				if !storageSeen[h.GetCapacity()] {
					storageSeen[h.GetCapacity()] = true
					storages = append(storages, h.GetCapacity())
				}

				rentalPence := h.GetRentalPrice().GetAmount()
				pence, _ := parsePenceFromMoney(rentalPence)
				if fromPricePence == 0 || pence < fromPricePence {
					fromPricePence = pence
				}

				variants = append(variants, &sharedmodel.MobileHandsetVariant{
					ID: h.GetId(),
					Attributes: []*sharedmodel.MobileHandsetAttribute{
						{Key: "colour", Value: h.GetColours()},
						{Key: "storage", Value: h.GetCapacity()},
					},
					MonthlyCharge: &sharedmodel.MobileMoney{
						Amount:   h.GetRentalPrice().GetAmount(),
						Currency: h.GetRentalPrice().GetCurrency(),
					},
					Rrp: &sharedmodel.MobileMoney{
						Amount:   h.GetRrp().GetAmount(),
						Currency: h.GetRrp().GetCurrency(),
					},
					InStock: true,
				})
			}

			first := data.handsets[0]
			optionTypes := []*sharedmodel.MobileHandsetOptionType{
				{Key: "colour", Values: colours},
				{Key: "storage", Values: storages},
			}

			phones = append(phones, &sharedmodel.MobileHandsetPhone{
				Model: modelName,
				FromPrice: &sharedmodel.MobileMoney{
					Amount:   fmt.Sprintf("%.2f", float64(fromPricePence)/100),
					Currency: "GBP",
				},
				ScreenSize:         first.GetScreenSize(),
				Battery:            first.GetBattery(),
				WiFiStandard:       first.GetWifiStandard(),
				ESim:               first.GetEsim(),
				DualSim:            first.GetDualSim(),
				SpecificationsLink: first.GetSpecificationsLink(),
				OptionTypes:        optionTypes,
				Variants:           variants,
			})
		}

		if len(phones) > 0 {
			brands = append(brands, &sharedmodel.MobileHandsetBrand{
				Name:   brandName,
				Phones: phones,
			})
		}
	}

	return brands, nil
}

func parsePenceFromMoney(amount string) (int32, error) {
	f, err := strconv.ParseFloat(amount, 64)
	if err != nil {
		return 0, err
	}
	return int32(f * 100), nil
}

