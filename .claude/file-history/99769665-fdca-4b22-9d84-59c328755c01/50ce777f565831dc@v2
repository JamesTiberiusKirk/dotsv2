	}

	return &model.MobileAddSimQuoteResponse{
		QuoteID:                  upgradeQuote.QuoteID,
		ExistingServices:         upgradeQuote.ExistingServices,
		AdditionalAvailablePlans: upgradeQuote.AdditionalAvailablePlans,
		AvailableHandsets:        upgradeQuote.AvailableHandsets,
		NewServices:              upgradeQuote.NewServices,
		RequestedChanges:         upgradeQuote.RequestedChanges,
		Cost:                     upgradeQuote.Cost,
		BillCustomerAddress:      upgradeQuote.BillCustomerAddress,
		EffectiveDate:            upgradeQuote.EffectiveDate,
		EstimatedDeliveryDate:    upgradeQuote.EstimatedDeliveryDate,
		SubmittedAt:              upgradeQuote.SubmittedAt,
		QuoteStatus:              upgradeQuote.QuoteStatus,
		Channel:                  upgradeQuote.Channel,
		Attributes:               upgradeQuote.Attributes,
	}, err
}

