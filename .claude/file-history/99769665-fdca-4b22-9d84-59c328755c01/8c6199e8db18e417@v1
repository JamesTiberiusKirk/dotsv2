extend type Query {
    mobileAddSimQuote(request: MobileAddSimQuoteRequest!): MobileAddSimQuoteResponse!
    mobileServiceUsage(request: MobileServiceUsageRequest!): MobileServiceUsageResponse!
    mobileServiceUsageHistory(request: MobileServiceUsageHistoryRequest!): [MobileServiceUsageHistoryResponse!]!
    mobileValidateOTPVerificationCode(request: MobileValidateOTPVerificationCodeRequest!): MobileValidateOTPVerificationCodeResponse!
