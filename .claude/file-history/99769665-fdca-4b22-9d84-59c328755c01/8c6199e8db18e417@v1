    # blacklisted.
    mobileBlacklistHandset(request: MobileBlacklistHandsetRequest!): MobileBlacklistHandsetResponse!
    mobilePortingIn(request: MobilePortingInRequest!): MobilePortingInResponse!
    mobileRequestSimReplacement(request: MobileSimReplacementRequest!): MobileSimReplacementResponse!
    mobileGenerateAndEmailEeccContract(request: MobileGenerateAndEmailEeccContractRequest!): MobileGenerateAndEmailEeccContractResponse!
