    mobileHandsetInformation(request: MobileHandsetInformationRequest!): MobileHandsetInformationResponse!
    mobileServices: MobileServicesResponse!
    mobileRoamingUsage(request: MobileRoamingUsageRequest!): MobileRoamingUsageResponse!
    mobileContractRenewalDate: MobileContractRenewalDateResponse!
    mobileGetBarredSimStatus(request: MobileGetBarredSimStatusRequest!): MobileGetBarredSimStatusResponse!
    mobileCanOrderReplacementESIM: MobileCanOrderReplacementESIMResponse
    mobileActivatableSims: [MobileActivatableSimResponse!]!
    mobileAddSimIsUpgradeAvailableWithPendingChanges: MobileAddSimUpgradeAvailabilityWithPendingResponse!
