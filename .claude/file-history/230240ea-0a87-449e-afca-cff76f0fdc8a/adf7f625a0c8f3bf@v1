package storage_test

import (
	"context"
	"errors"
	"time"

	. "github.com/onsi/ginkgo/v2"
	. "github.com/onsi/gomega"
	"go.mongodb.org/mongo-driver/bson"
	"go.mongodb.org/mongo-driver/mongo"
	"go.uber.org/mock/gomock"

	"github.com/utilitywarehouse/telecom-mobile/pkg/libdry/terrors"
	"github.com/utilitywarehouse/telecom-mobile/services/handset/internal/models"
	"github.com/utilitywarehouse/telecom-mobile/services/handset/internal/storage"
	mockStorage "github.com/utilitywarehouse/telecom-mobile/services/handset/internal/storage/mocks"
)

var testContractID = "22222222-2222-2222-2222-222222222222"

var _ = Describe("Contract Storage", func() {
	var (
		ctrl          *gomock.Controller
		mockContracts *mockStorage.MockMongoCollection
		ctx           context.Context
		store         *storage.StorageWrapper
	)

	BeforeEach(func() {
		ctrl = gomock.NewController(GinkgoT())
		mockContracts = mockStorage.NewMockMongoCollection(ctrl)
		store = storage.NewStorageWithCollections(mockContracts, mockContracts, mockContracts, time.Now)
		ctx = context.Background()
	})

	AfterEach(func() {
		ctrl.Finish()
	})

	Describe("CreateContract", func() {
		It("inserts a contract into the collection", func() {
			contract := models.Contract{
				ID:         testContractID,
				ServiceID:  "service-1",
				CustomerID: "customer-1",
				HandsetID:  "handset-1",
				RequestID:  "request-1",
				Status:     models.ContractStatusPendingEligibility,
				CreatedAt:  time.Now(),
				UpdatedAt:  time.Now(),
			}

			mockContracts.EXPECT().
				InsertOne(gomock.Any(), contract).
				Return(&mongo.InsertOneResult{}, nil)

			err := store.CreateContract(ctx, contract)
			Expect(err).ToNot(HaveOccurred())
		})

		When("the insert fails", func() {
			It("returns an error", func() {
				contract := models.Contract{
					ID:        testContractID,
					RequestID: "request-1",
					Status:    models.ContractStatusPendingEligibility,
				}

				mockContracts.EXPECT().
					InsertOne(gomock.Any(), contract).
					Return(nil, errors.New("duplicate key"))

				err := store.CreateContract(ctx, contract)
				Expect(err).To(HaveOccurred())
				Expect(err.Error()).To(ContainSubstring("could not create contract"))
			})
		})
	})

	Describe("GetContractByRequestID", func() {
		It("returns the contract matching the request ID", func() {
			expectedContract := models.Contract{
				ID:         testContractID,
				ServiceID:  "service-1",
				CustomerID: "customer-1",
				HandsetID:  "handset-1",
				RequestID:  "request-1",
				Status:     models.ContractStatusPendingEligibility,
			}

			singleResult := mongo.NewSingleResultFromDocument(expectedContract, nil, nil)

			mockContracts.EXPECT().
				FindOne(gomock.Any(), gomock.Any()).
				Return(singleResult)

			contract, err := store.GetContractByRequestID(ctx, "request-1")
			Expect(err).ToNot(HaveOccurred())
			Expect(contract).ToNot(BeNil())
			Expect(contract.ID).To(Equal(testContractID))
			Expect(contract.RequestID).To(Equal("request-1"))
			Expect(contract.Status).To(Equal(models.ContractStatusPendingEligibility))
		})

		When("no contract is found", func() {
			It("returns ErrContractNotFound", func() {
				singleResult := mongo.NewSingleResultFromDocument(models.Contract{}, mongo.ErrNoDocuments, nil)

				mockContracts.EXPECT().
					FindOne(gomock.Any(), gomock.Any()).
					Return(singleResult)

				contract, err := store.GetContractByRequestID(ctx, "nonexistent-request")
				Expect(err).To(MatchError(terrors.ErrNotFound))
				Expect(contract).To(BeNil())
			})
		})
	})

	Describe("GetActiveContractForService", func() {
		It("returns an active contract for the service", func() {
			expectedContract := models.Contract{
				ID:        testContractID,
				ServiceID: "service-1",
				Status:    models.ContractStatusApproved,
			}

			singleResult := mongo.NewSingleResultFromDocument(expectedContract, nil, nil)

			mockContracts.EXPECT().
				FindOne(gomock.Any(), gomock.Any()).
				Return(singleResult)

			contract, err := store.GetActiveContractForService(ctx, "service-1")
			Expect(err).ToNot(HaveOccurred())
			Expect(contract).ToNot(BeNil())
			Expect(contract.ServiceID).To(Equal("service-1"))
		})

		When("no active contract exists", func() {
			It("returns ErrContractNotFound", func() {
				singleResult := mongo.NewSingleResultFromDocument(models.Contract{}, mongo.ErrNoDocuments, nil)

				mockContracts.EXPECT().
					FindOne(gomock.Any(), gomock.Any()).
					Return(singleResult)

				contract, err := store.GetActiveContractForService(ctx, "service-1")
				Expect(err).To(MatchError(terrors.ErrNotFound))
				Expect(contract).To(BeNil())
			})
		})
	})

	Describe("CustomerHasDeclinedContract", func() {
		var (
			testNow time.Time
			nowFunc func() time.Time
		)

		BeforeEach(func() {
			testNow = time.Date(2024, 1, 25, 12, 0, 0, 0, time.UTC)
			nowFunc = func() time.Time { return testNow }
			store = storage.NewStorageWithCollections(mockContracts, mockContracts, mockContracts, nowFunc)
		})

		When("a declined contract exists within the duration", func() {
			It("returns true", func() {
				expectedContract := models.Contract{
					ID:         testContractID,
					CustomerID: "customer-1",
					Status:     models.ContractStatusDeclined,
					CreatedAt:  testNow.Add(-24 * time.Hour),
				}

				singleResult := mongo.NewSingleResultFromDocument(expectedContract, nil, nil)

				mockContracts.EXPECT().
					FindOne(gomock.Any(), gomock.Any()).
					Return(singleResult)

				result, err := store.CustomerHasDeclinedContract(ctx, "customer-1", 48*time.Hour)
				Expect(err).ToNot(HaveOccurred())
				Expect(result).To(BeTrue())
			})
		})

		When("no declined contract exists within the duration", func() {
			It("returns false", func() {
				singleResult := mongo.NewSingleResultFromDocument(models.Contract{}, mongo.ErrNoDocuments, nil)

				mockContracts.EXPECT().
					FindOne(gomock.Any(), gomock.Any()).
					Return(singleResult)

				result, err := store.CustomerHasDeclinedContract(ctx, "customer-1", 48*time.Hour)
				Expect(err).ToNot(HaveOccurred())
				Expect(result).To(BeFalse())
			})
		})

		When("the query fails", func() {
			It("returns an error", func() {
				singleResult := mongo.NewSingleResultFromDocument(models.Contract{}, errors.New("connection error"), nil)

				mockContracts.EXPECT().
					FindOne(gomock.Any(), gomock.Any()).
					Return(singleResult)

				result, err := store.CustomerHasDeclinedContract(ctx, "customer-1", 48*time.Hour)
				Expect(err).To(HaveOccurred())
				Expect(err.Error()).To(ContainSubstring("could not check for declined contract"))
				Expect(result).To(BeFalse())
			})
		})
	})

	Describe("FindAndUpdateExpiredContracts", func() {
		var (
			testNow time.Time
			nowFunc func() time.Time
		)

		BeforeEach(func() {
			testNow = time.Date(2025, 1, 1, 12, 0, 0, 0, time.UTC)
			nowFunc = func() time.Time { return testNow }
			store = storage.NewStorageWithCollections(mockContracts, mockContracts, mockContracts, nowFunc)
		})

		When("no expired contracts exist", func() {
			It("returns an empty list", func() {
				mockContracts.EXPECT().
					FindOneAndUpdate(gomock.Any(), gomock.Any(), gomock.Any(), gomock.Any()).
					Return(mongo.NewSingleResultFromDocument(models.Contract{}, mongo.ErrNoDocuments, nil))

				contracts, err := store.FindAndUpdateExpiredContracts(ctx)
				Expect(err).ToNot(HaveOccurred())
				Expect(contracts).To(BeEmpty())
			})
		})

		When("multiple expired contracts exist", func() {
			It("returns all expired contracts", func() {
				contract1 := models.Contract{ID: testContractID, Status: models.ContractStatusExpired}
				contract2ID := "33333333-3333-3333-3333-333333333333"
				contract2 := models.Contract{ID: contract2ID, Status: models.ContractStatusExpired}

				gomock.InOrder(
					mockContracts.EXPECT().
						FindOneAndUpdate(gomock.Any(), gomock.Any(), gomock.Any(), gomock.Any()).
						Return(mongo.NewSingleResultFromDocument(contract1, nil, nil)),
					mockContracts.EXPECT().
						FindOneAndUpdate(gomock.Any(), gomock.Any(), gomock.Any(), gomock.Any()).
						Return(mongo.NewSingleResultFromDocument(contract2, nil, nil)),
					mockContracts.EXPECT().
						FindOneAndUpdate(gomock.Any(), gomock.Any(), gomock.Any(), gomock.Any()).
						Return(mongo.NewSingleResultFromDocument(models.Contract{}, mongo.ErrNoDocuments, nil)),
				)

				contracts, err := store.FindAndUpdateExpiredContracts(ctx)
				Expect(err).ToNot(HaveOccurred())
				Expect(contracts).To(HaveLen(2))
				Expect(contracts[0].ID).To(Equal(testContractID))
				Expect(contracts[1].ID).To(Equal(contract2ID))
			})
		})

		When("an error occurs mid-loop", func() {
			It("returns partial results alongside the error", func() {
				contract1 := models.Contract{ID: testContractID, Status: models.ContractStatusExpired}

				gomock.InOrder(
					mockContracts.EXPECT().
						FindOneAndUpdate(gomock.Any(), gomock.Any(), gomock.Any(), gomock.Any()).
						Return(mongo.NewSingleResultFromDocument(contract1, nil, nil)),
					mockContracts.EXPECT().
						FindOneAndUpdate(gomock.Any(), gomock.Any(), gomock.Any(), gomock.Any()).
						Return(mongo.NewSingleResultFromDocument(models.Contract{}, errors.New("connection error"), nil)),
				)

				contracts, err := store.FindAndUpdateExpiredContracts(ctx)
				Expect(err).To(HaveOccurred())
				Expect(err.Error()).To(ContainSubstring("could not expire contract"))
				Expect(contracts).To(HaveLen(1))
				Expect(contracts[0].ID).To(Equal(testContractID))
			})
		})
	})

	Describe("UpdateContractEligibilityApproved", func() {
		When("signedAt is set", func() {
			It("sends a pipeline update with expiresAt computed via $dateAdd on $contractMonths", func() {
				signedAt := time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC)

				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					DoAndReturn(func(_ context.Context, _, update any, _ ...any) (*mongo.UpdateResult, error) {
						pipeline, ok := update.(mongo.Pipeline)
						Expect(ok).To(BeTrue(), "expected a pipeline update when signedAt is set")
						setFields := pipeline[0][0].Value.(bson.M)
						Expect(setFields["signedAt"]).To(Equal(&signedAt))
						Expect(setFields["expiresAt"]).To(Equal(bson.M{
							"$dateAdd": bson.M{
								"startDate": &signedAt,
								"unit":      "month",
								"amount":    bson.M{"$toInt": "$contractMonths"},
							},
						}))
						return &mongo.UpdateResult{MatchedCount: 1}, nil
					})

				err := store.UpdateContractEligibilityApproved(ctx, "request-1", models.EligibilityOutcome{
					SignedAt: &signedAt,
				})
				Expect(err).ToNot(HaveOccurred())
			})
		})

		When("signedAt is nil", func() {
			It("sends a regular update without expiresAt", func() {
				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					DoAndReturn(func(_ context.Context, _, update any, _ ...any) (*mongo.UpdateResult, error) {
						setFields := update.(bson.M)["$set"].(bson.M)
						Expect(setFields).NotTo(HaveKey("expiresAt"))
						return &mongo.UpdateResult{MatchedCount: 1}, nil
					})

				err := store.UpdateContractEligibilityApproved(ctx, "request-1", models.EligibilityOutcome{
					SignedAt: nil,
				})
				Expect(err).ToNot(HaveOccurred())
			})
		})
	})

	Describe("UpdateContractStatus", func() {
		It("updates the contract status", func() {
			mockContracts.EXPECT().
				UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
				Return(&mongo.UpdateResult{MatchedCount: 1, ModifiedCount: 1}, nil)

			err := store.UpdateContractStatus(ctx, "request-1", models.ContractStatusApproved)
			Expect(err).ToNot(HaveOccurred())
		})

		When("no contract matches the guarded transition", func() {
			It("returns ErrContractStatusConflict", func() {
				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					Return(&mongo.UpdateResult{MatchedCount: 0}, nil)

				err := store.UpdateContractStatus(ctx, "nonexistent-request", models.ContractStatusDeclined)
				Expect(err).To(MatchError(terrors.ErrConflict))
			})
		})

		When("the update fails", func() {
			It("returns an error", func() {
				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					Return(nil, errors.New("connection error"))

				err := store.UpdateContractStatus(ctx, "request-1", models.ContractStatusApproved)
				Expect(err).To(HaveOccurred())
				Expect(err.Error()).To(ContainSubstring("could not update contract status"))
			})
		})
	})

	Describe("DecrementHandsetOrdersPlaced", func() {
		It("decrements ordersPlaced on the matching handset", func() {
			mockContracts.EXPECT().
				UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
				Return(&mongo.UpdateResult{MatchedCount: 1, ModifiedCount: 1}, nil)

			err := store.DecrementHandsetOrdersPlaced(ctx, testContractID)
			Expect(err).ToNot(HaveOccurred())
		})

		When("the update fails", func() {
			It("returns an error", func() {
				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					Return(nil, errors.New("connection error"))

				err := store.DecrementHandsetOrdersPlaced(ctx, testContractID)
				Expect(err).To(HaveOccurred())
				Expect(err.Error()).To(ContainSubstring("could not decrement orders placed"))
			})
		})
	})

	Describe("IncrementHandsetOrdersPlaced", func() {
		It("increments ordersPlaced on the matching handset", func() {
			mockContracts.EXPECT().
				UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
				Return(&mongo.UpdateResult{MatchedCount: 1, ModifiedCount: 1}, nil)

			err := store.IncrementHandsetOrdersPlaced(ctx, testContractID)
			Expect(err).ToNot(HaveOccurred())
		})

		When("no handset matches the ID", func() {
			It("returns ErrNotFound", func() {
				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					Return(&mongo.UpdateResult{MatchedCount: 0}, nil)

				err := store.IncrementHandsetOrdersPlaced(ctx, testContractID)
				Expect(err).To(MatchError(terrors.ErrNotFound))
			})
		})

		When("the update fails", func() {
			It("returns an error", func() {
				mockContracts.EXPECT().
					UpdateOne(gomock.Any(), gomock.Any(), gomock.Any()).
					Return(nil, errors.New("connection error"))

				err := store.IncrementHandsetOrdersPlaced(ctx, testContractID)
				Expect(err).To(HaveOccurred())
				Expect(err.Error()).To(ContainSubstring("could not increment orders placed"))
			})
		})
	})
})
