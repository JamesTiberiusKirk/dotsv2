func (s storage) CustomerHasDeclinedContract(ctx context.Context, customerID string, since time.Duration) (bool, error) {
	filter := bson.M{
		"customerId": customerID,
		"status":     models.ContractStatusDeclined,
		"createdAt":  bson.M{"$gte": s.nowFunc().Add(-since)},
	}

	var contract models.Contract
	err := s.contractsCollection.FindOne(ctx, filter).Decode(&contract)
	if err != nil {
		if errors.Is(err, mongo.ErrNoDocuments) {
			return false, nil
		}
		return false, fmt.Errorf("could not check for declined contract: %w", err)
	}
	return true, nil
}

func (s storage) GetStockLedgerByBillID(ctx context.Context, billID string) ([]models.StockLedgerEntry, error) {
	cur, err := s.stockLedgerCollection.Find(ctx, bson.M{"billID": billID})
	if err != nil {
		return nil, fmt.Errorf("could not find stock ledger entries: %w", err)
	}

	defer func(cur *mongo.Cursor, ctx context.Context) {
		err := cur.Close(ctx)
		if err != nil {
			tlog.Error(ctx, "could not close cursor: %s", err.Error())
		}
	}(cur, ctx)

	var entries []models.StockLedgerEntry
	for cur.Next(ctx) {
		var entry models.StockLedgerEntry
		if err := cur.Decode(&entry); err != nil {
			return nil, fmt.Errorf("could not decode stock ledger entry: %w", err)
		}
		entries = append(entries, entry)
	}

	if err := cur.Err(); err != nil {
		return nil, fmt.Errorf("error iterating over stock ledger entries: %w", err)
	}

	return entries, nil
}

func (s storage) InsertStockLedgerEntry(ctx context.Context, entry models.StockLedgerEntry) error {
	_, err := s.stockLedgerCollection.UpdateOne(
		ctx,
		bson.M{"hash": entry.Hash},
		bson.M{"$setOnInsert": entry},
		options.Update().SetUpsert(true),
	)
	if err != nil {
		return fmt.Errorf("could not insert stock ledger entry: %w", err)
	}
	return nil
}

func (s storage) IncrementHandsetOrdersPlaced(ctx context.Context, handsetID string) error {
	result, err := s.handsetsCollection.UpdateOne(
		ctx,
		bson.D{
			{Key: "id", Value: handsetID},
			{Key: "$expr", Value: bson.D{
				{Key: "$lt", Value: bson.A{"$ordersPlaced", "$stockBase"}},
			}},
		},
		bson.M{"$inc": bson.M{"ordersPlaced": 1}},
	)
	if err != nil {
		return fmt.Errorf("could not increment orders placed: %w", err)
	}
	if result.MatchedCount == 0 {
		return terrors.ErrNotFound
	}
	return nil
}

func (s storage) DecrementHandsetOrdersPlaced(ctx context.Context, handsetID string) error {
	result, err := s.handsetsCollection.UpdateOne(
		ctx,
		bson.D{
			{Key: "id", Value: handsetID},
			{Key: "$expr", Value: bson.D{{Key: "$gt", Value: bson.A{"$ordersPlaced", 0}}}},
		},
		bson.M{"$inc": bson.M{"ordersPlaced": -1}},
	)
	if err != nil {
		return fmt.Errorf("could not decrement orders placed: %w", err)
	}
	// If nothing matched, treat as a no-op to avoid driving the counter negative.
	_ = result
	return nil
}

func (s storage) ComputeAndSetHandsetStockBase(ctx context.Context, billID string) error {
	matchStage := bson.D{
		{Key: "$match", Value: bson.D{
			{Key: "billID", Value: billID},
		}},
	}

	groupStage := bson.D{
		{Key: "$group", Value: bson.D{
			{Key: "_id", Value: "$billID"},
			{Key: "stockBase", Value: bson.D{
				{Key: "$sum", Value: bson.D{
					{Key: "$subtract", Value: bson.A{"$stockAdded", "$stockRemoved"}},
				}},
			}},
		}},
	}

	addFieldsStage := bson.D{
		{Key: "$addFields", Value: bson.D{
			{Key: "billID", Value: "$_id"},
		}},
	}

	mergeStage := bson.D{
		{Key: "$merge", Value: bson.D{
			{Key: "into", Value: collectionHandsets},
			{Key: "on", Value: "billID"},
			{Key: "whenMatched", Value: mongo.Pipeline{
				{{Key: "$set", Value: bson.D{
					{Key: "stockBase", Value: "$$new.stockBase"},
				}}},
			}},
			{Key: "whenNotMatched", Value: "discard"},
		}},
	}

	pipeline := mongo.Pipeline{matchStage, groupStage, addFieldsStage, mergeStage}

	cur, err := s.stockLedgerCollection.Aggregate(ctx, pipeline)
	if err != nil {
		return fmt.Errorf("could not compute and set stock base: %w", err)
	}

	return cur.Close(ctx)
}

// StorageWrapper is an exported type that wraps the internal storage struct,
// allowing tests to inject mock collections without needing a real MongoDB connection.
type StorageWrapper struct {
	storage
}

// NewStorageWithCollections creates a StorageWrapper with the given collections injected.
// Intended for use in tests.
func NewStorageWithCollections(handsetsCollection, contractsCollection, stockLedgerCollection MongoCollection, nowFunc func() time.Time) *StorageWrapper {
	return &StorageWrapper{
		storage: storage{
			handsetsCollection:    handsetsCollection,
			contractsCollection:   contractsCollection,
			stockLedgerCollection: stockLedgerCollection,
			nowFunc:               nowFunc,
		},
	}
}
