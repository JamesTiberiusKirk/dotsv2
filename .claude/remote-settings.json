      "Bash(pnpm add *)",
      "Bash(pnpm install)",
      "Bash(npx add *)",
      "Bash(go mod *)"
    ],
    "deny": [
      "Bash(chmod 777 *)",
      "Bash(curl *)",
      "Bash(ssh *)",
      "Bash(scp *)",
