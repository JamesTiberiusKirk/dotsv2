      "Bash(mockgen *)",
      "Bash(moq *)",
      "Bash(npm run *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx tsc *)",
      "Bash(pnpm run *)",
      "Bash(protoc *)",
      "Bash(semgrep *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(yarn run *)"
