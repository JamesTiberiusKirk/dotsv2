      "mcp__linear-server__save_milestone",
      "mcp__linear-server__save_project",
      "mcp__linear-server__save_status_update",
      "mcp__linear-server__search_documentation",
      "mcp__linear-server__update_document",
      "mcp__linear-server__update_issue",
      "mcp__linear-server__update_project",
      "mcp__playwright__*",
      "Read(**/secrets/**)",
      "Read(./.env.*)",
      "Read(./.env)",
      "Read(./**/strongbox-keyring)",
      "Read(.aws/**)",
      "Read(.kube/**)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "respectGitignore": true,
  "sandbox": {
    "allowUnsandboxedCommands": false,
    "enabled": true,
    "filesystem": {
      "allowRead": [
        ".",
        "~/.ssh/config",
        "~/.ssh/known_hosts",
        "~/.ssh/id_*",
        "~/.config/gh/",
        "~/.cache/go-build",
        "~/.cache/nix",
        "~/.cargo/bin",
        "~/.cargo/registry/",
        "~/.claude/",
        "~/.config/git/ignore",
        "~/.config/gh",
        "~/.config/gh",
        "~/.config/go",
        "~/.gitconfig",
        "~/.gnupg",
        "~/.npm",
        "~/.nvm",
        "~/.pnpm-store",
        "~/go/bin",
        "~/go/pkg",
        "~/go/pkg/mod/cache/",
        "~/Library/Application Support/go",
        "~/Library/Caches/",
        "~/.cache/nix",
        "~/.cache/node"
      ],
      "allowWrite": [
        "~/.ssh/known_hosts",
        "~/.config/gh/",
        "~/go/bin",
        "~/go/pkg/mod/",
        "~/go/pkg/mod/cache/",
        "~/Library/Caches/",
        "~/.cache/nix",
        "~/.cache/node"
      ],
      "denyRead": [
        "**/.env.*",
        "**/.env",
        "~/.aws",
        "~/.cursor",
        "~/.kube",
        "~/"
      ],
      "denyWrite": [
        "/etc",
        "/usr/bin",
        "/usr/local/bin",
        "~/.aws",
        "~/.claude/policy-limits.json",
        "~/.claude/remote-settings.json",
        "~/.cursor",
        "~/.kube"
      ]
    },
    "network": {
      "allowUnixSockets": [
        "~/.ssh/agent-socket",
        "/private/var/folders/*/*/T/com.apple.launchd.*/Listeners",
        "/run/user/*/ssh-agent.socket"
      ],
      "allowedDomains": [
        "*.anthropic.com",
        "*.dev.*.uw.systems",
        "*.figma.com",
        "*.linear.app",
        "*.uw.je",
        "anthropic.com",
        "api.github.com",
