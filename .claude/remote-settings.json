{
  "allowManagedMcpServersOnly": true,
  "allowManagedPermissionRulesOnly": true,
  "allowedMcpServers": [
    {
      "serverUrl": "https://mcp.linear.app/*"
    },
    {
      "serverUrl": "https://mcp.figma.com/*"
    }
  ],
  "autoUpdatesChannel": "stable",
  "availableModels": [
    "claude-sonnet-4-5",
    "claude-haiku-4-5",
    "claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]",
    "claude-opus-4-6",
    "claude-opus-4-6[1m]",
    "claude-haiku-4-6"
  ],
  "cleanupPeriodDays": 30,
  "companyAnnouncements": [
    "Claude code runs with a sandbox, so some commands may not work as expected. If you need to run a command that is not allowed, please ask the DevSecOps team for help and read their docs before using this tool: https://wiki.uw.systems/posts/ai-coding-tools-uqsbqyvj.\nPlease give your feedback on Slack: #tool-claude. \nUsage of claude is governed by this policy: https://policy.prod.uw.systems/policies/ai-in-the-workplace-policy.pdf . \nThe rules and sandbox are maintained here: https://github.com/UtilityWarehouse/ai-coding-rules. - UW Claude Code"
  ],
  "disableAutoMode": "disable",
  "disableRemoteControl": true,
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_EXPORTER_OTLP_HEADERS": "Authorization=Basic Y2xhdWRlLWNvZGU6dmVsdmV0LXNwaGlueC1jb2JhbHQtZ2xpZGVy",
    "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT": "https://logs.exp-1.aws.uw.systems/v1/logs",
    "OTEL_EXPORTER_OTLP_LOGS_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_METRICS_ENDPOINT": "https://thanos-receive-system.exp-1.aws.uw.systems/api/v1/otlp",
    "OTEL_EXPORTER_OTLP_METRICS_HEADERS": "Authorization=Basic Y2xhdWRlLWNvZGU6cGxveS1rbmVsdC1jaXRhZGVsLXNtaWxpbmdseS1leGhhdXN0",
    "OTEL_EXPORTER_OTLP_METRICS_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000",
    "OTEL_LOG_TOOL_CONTENT": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_METRICS_INCLUDE_ACCOUNT_UUID": "true",
    "OTEL_METRICS_INCLUDE_ENTRYPOINT": "true",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "true",
    "OTEL_METRICS_INCLUDE_VERSION": "true",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000"
  },
  "forceRemoteSettingsRefresh": true,
  "minimumVersion": "2.1.139",
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(buf *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
