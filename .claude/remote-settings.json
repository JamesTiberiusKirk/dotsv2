      "Bash(uv *)",
      "Bash(npm add *)",
      "Bash(npm ci *)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(yarn add *)",
      "Bash(yarn install)",
      "Bash(yarn *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(go install *)",
      "Bash(cargo add *)",
      "Bash(cargo fetch *)",
      "Bash(cargo install *)",
      "Bash(cargo update *)",
