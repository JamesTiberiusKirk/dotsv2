#!/usr/bin/env bash
set -e

MODE="$1"
case "$MODE" in
    dark|light) ;;
    *) echo "usage: $0 <dark|light>" >&2; exit 2 ;;
esac

echo "$MODE" > ~/.theme-mode

gtk3_settings="$HOME/.config/gtk-3.0/settings.ini"
gtk4_settings="$HOME/.config/gtk-4.0/settings.ini"

# alacritty — swap imported palette; alacritty live-reloads on mtime change
ln -sfn ~/.config/alacritty/colors-"$MODE".toml ~/.config/alacritty/colors.toml
touch ~/.config/alacritty/alacritty.toml

# i3 — swap include target, reload
ln -sfn ~/.config/i3/colors-"$MODE".conf ~/.config/i3/colors.conf
i3-msg -q reload >/dev/null 2>&1 || true

# dunst — swap dunstrc symlink, reload
ln -sfn ~/.config/dunst/dunstrc-"$MODE" ~/.config/dunst/dunstrc
dunstctl reload >/dev/null 2>&1 || { pkill -x dunst >/dev/null 2>&1 || true; setsid dunst >/dev/null 2>&1 & }

# Push the theme into running Neovim instances instead of waiting for portal polling.
for server in /run/user/"$(id -u)"/nvim.*; do
    [ -S "$server" ] || continue
    nvim --server "$server" --remote-expr "execute('ThemeSync $MODE')" >/dev/null 2>&1 || true
done

# GTK apps + nvim auto-dark-mode
if [ "$MODE" = dark ]; then
    gtk_theme='Materia-dark-compact'
    color_scheme='prefer-dark'
else
    gtk_theme='Materia-light-compact'
    color_scheme='prefer-light'
fi

mkdir -p "${gtk3_settings%/*}" "${gtk4_settings%/*}"

write_gtk_settings() {
    local target="$1"
    cat > "$target" <<EOF
[Settings]
gtk-theme-name=$gtk_theme
gtk-icon-theme-name=Adwaita
gtk-font-name=Adwaita Sans 11
gtk-cursor-theme-name=Adwaita
gtk-cursor-theme-size=0
gtk-toolbar-style=GTK_TOOLBAR_BOTH_HORIZ
gtk-toolbar-icon-size=GTK_ICON_SIZE_LARGE_TOOLBAR
gtk-button-images=0
gtk-menu-images=0
gtk-enable-event-sounds=1
gtk-enable-input-feedback-sounds=1
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=rgb
gtk-application-prefer-dark-theme=$([ "$MODE" = dark ] && echo 1 || echo 0)
gtk-color-scheme=$color_scheme
EOF
}

write_gtk_settings "$gtk3_settings"
write_gtk_settings "$gtk4_settings"

gsettings set org.gnome.desktop.interface color-scheme "$color_scheme" >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" >/dev/null 2>&1 || true
gsettings set org.mate.interface gtk-theme "$gtk_theme" >/dev/null 2>&1 || true

if command -v xfconf-query >/dev/null 2>&1; then
    xfconf-query -c xsettings -p /Net/ThemeName -n -t string -s "$gtk_theme" >/dev/null 2>&1 || true
    xfconf-query -c xsettings -p /Net/IconThemeName -n -t string -s Adwaita >/dev/null 2>&1 || true
    xfconf-query -c xsettings -p /Gtk/CursorThemeName -n -t string -s Adwaita >/dev/null 2>&1 || true
    xfconf-query -c xsettings -p /Gtk/CursorThemeSize -n -t int -s 0 >/dev/null 2>&1 || true
fi

# Thunar does not reliably repaint on theme changes in this i3 session.
# Restart it if it is already running so the new GTK theme is applied.
if pgrep -x thunar >/dev/null 2>&1; then
    thunar --quit >/dev/null 2>&1 || pkill -x thunar >/dev/null 2>&1 || true
    setsid thunar >/dev/null 2>&1 &
fi
