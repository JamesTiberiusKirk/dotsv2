#!/usr/bin/env python3
import json
import subprocess
import sys
import time


def read_meminfo():
    info = {}
    with open("/proc/meminfo", "r", encoding="utf-8") as f:
        for line in f:
            if ":" not in line:
                continue
            key, rest = line.split(":", 1)
            parts = rest.strip().split()
            if not parts:
                continue
            try:
                info[key] = int(parts[0])
            except ValueError:
                continue
    return info


def mem_stats_kb():
    info = read_meminfo()
    total = info.get("MemTotal", 0)
    available = info.get("MemAvailable", info.get("MemFree", 0))
    buffers = info.get("Buffers", 0)
    cached = info.get("Cached", 0)
    sreclaim = info.get("SReclaimable", 0)
    shmem = info.get("Shmem", 0)
    cache = max(0, buffers + cached + sreclaim - shmem)
    used = max(0, total - available)
    return used, cache, total


def swap_stats_kb():
    info = read_meminfo()
    total = info.get("SwapTotal", 0)
    free = info.get("SwapFree", 0)
    used = max(0, total - free)
    return used, total


def fmt_kb(kb):
    gib = kb / 1024 / 1024
    if gib >= 10:
        return f"{gib:.0f}G"
    return f"{gib:.1f}G"


UPDATES_FILE = "/tmp/i3status_updates"

_docker_cache = {"result": None, "time": 0}
DOCKER_CACHE_SECS = 30


def _docker_socket_exists():
    import os
    return os.path.exists("/var/run/docker.sock")


def docker_block():
    if not _docker_socket_exists():
        return {"full_text": "🐳 off", "name": "docker", "color": "#ff0000"}

    now = time.monotonic()
    if _docker_cache["result"] and now - _docker_cache["time"] < DOCKER_CACHE_SECS:
        return _docker_cache["result"]
    try:
        result = subprocess.run(
            ["docker", "ps", "-q"],
            capture_output=True,
            text=True,
            timeout=1,
        )
    except FileNotFoundError:
        return {"full_text": "🐳 n/a", "name": "docker", "color": "#ff0000"}
    except subprocess.TimeoutExpired:
        return {"full_text": "🐳 timeout", "name": "docker", "color": "#ff0000"}

    if result.returncode != 0:
        return {"full_text": "🐳 off", "name": "docker", "color": "#ff0000"}

    count = len([line for line in result.stdout.splitlines() if line.strip()])
    block = {
        "full_text": f"🐳 {count}",
        "name": "docker",
        "color": "#00ff00",
    }
    _docker_cache["result"] = block
    _docker_cache["time"] = now
    return block


def updates_block():
    try:
        with open(UPDATES_FILE, "r", encoding="utf-8") as file_handle:
            value = file_handle.read().strip()
    except FileNotFoundError:
        return {"full_text": "📦 n/a", "name": "updates", "color": "#ff0000"}

    if not value:
        return {"full_text": "📦 n/a", "name": "updates", "color": "#ff0000"}

    if value.isdigit():
        count = int(value)
        color = "#00ff00" if count == 0 else "#ffff00"
        return {"full_text": f"📦 {count}", "name": "updates", "color": color}

    return {"full_text": f"📦 {value}", "name": "updates", "color": "#ff0000"}


def make_block():
    used, cache, total = mem_stats_kb()
    return {
        "full_text": f"🧠 {fmt_kb(used)} / {fmt_kb(cache)} / {fmt_kb(total)}",
        "name": "mem_uct",
    }


def make_swap_block():
    used, total = swap_stats_kb()
    return {
        "full_text": f"🔁 {fmt_kb(used)} / {fmt_kb(total)}",
        "name": "swap_ut",
    }


def should_hide_block(block):
    """Hide blocks for hardware that doesn't exist on this system."""
    name = block.get("name", "")
    text = block.get("full_text", "")

    # No laptop battery — hide "No battery"
    if name == "battery" and "No battery" in text:
        return True

    # No backlight hardware — hide error output
    instance = block.get("instance", "")
    if name == "read_file" and "brightness" in instance and "No such file" in text:
        return True

    # WiFi adapter not in use — hide "W: down"
    if name == "wireless" and "W: down" in text:
        return True

    # Docker daemon not running — hide "off"
    if name == "docker" and "off" in text:
        return True

    return False


def insert_after_name(blocks, block, names):
    for index, item in enumerate(blocks):
        if item.get("name") in names:
            blocks.insert(index + 1, block)
            return
    blocks.append(block)


def main():
    proc = subprocess.Popen(
        ["i3status"], stdout=subprocess.PIPE, text=True, bufsize=1
    )
    assert proc.stdout is not None

    for line in proc.stdout:
        line = line.rstrip("\n")
        if line.startswith('{"version"') or line == "[":
            print(line, flush=True)
            continue

        prefix = ""
        if line.startswith(","):
            prefix = ","
            line = line[1:]

        try:
            data = json.loads(line)
        except json.JSONDecodeError:
            print(prefix + line, flush=True)
            continue

        mem_block = make_block()
        swap_block = make_swap_block()
        docker_status = docker_block()
        updates_status = updates_block()
        if isinstance(data, list):
            data = [b for b in data if not should_hide_block(b)]
            if not should_hide_block(docker_status):
                insert_after_name(data, docker_status, {"ethernet"})
            if not should_hide_block(updates_status):
                insert_after_name(data, updates_status, {"docker"})
            if len(data) >= 1:
                data.insert(len(data) - 1, mem_block)
                data.insert(len(data) - 1, swap_block)
            else:
                data.append(mem_block)
                data.append(swap_block)

        print(prefix + json.dumps(data, ensure_ascii=False), flush=True)


if __name__ == "__main__":
    main()
