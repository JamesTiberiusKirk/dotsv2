# Alt + vim keys → arrow keys (built-in keyboard navigation layer)
# Caps Lock → Ctrl: set per-device in System Settings > Keyboard > Modifier Keys
alt - h : skhd -k "left"
alt - l : skhd -k "right"
alt - k : skhd -k "up"
alt - j : skhd -k "down"

# Swap workspaces between monitors (suppresses macOS app switcher)
cmd - tab : ~/.scripts/swap-workspaces-mac.sh

# Screenshot selection → clipboard (remaps Cmd+Shift+4 behaviour)
cmd + shift - s : screencapture -i -u ~/Pictures/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png
